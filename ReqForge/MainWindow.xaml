<Window x:Class="ReqForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        
        xmlns:local="clr-namespace:ReqForge"
        xmlns:models="clr-namespace:ReqForge.Models"
        xmlns:vm="clr-namespace:ReqForge.ViewModels"
        xmlns:helpers="clr-namespace:ReqForge.Helpers"
        mc:Ignorable="d"
        
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        
        Title="ReqForge" Width="1200" Height="750" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}"/>
        <helpers:MethodToColorConverter x:Key="MethodToColorConverter"/>
        <helpers:NullToBoolConverter x:Key="SelectedToEnabledConverter"/>
        <helpers:StatusCodeToBrushConverter x:Key="StatusCodeToBrushConverter"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <helpers:StringMatchToVisibilityConverter x:Key="StringMatchToVisibilityConverter"/>
        <helpers:BoolToTestResultBrushConverter x:Key="BoolToTestResultBrushConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10,10,10,8">
                <Button Content="NEW COLLECTION" 
                        Command="{Binding CreateCollectionCommand}"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Margin="0,0,0,5"/>
                <Button Content="SAVE CURRENT" 
                        Command="{Binding SaveRequestCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        ToolTip="Save current request to selected collection"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Button Content="EXPORT"
                            Command="{Binding ExportCollectionsCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Width="125"
                            Margin="0,0,5,0"/>
                    <Button Content="IMPORT"
                            Command="{Binding ImportCollectionsCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Width="125"/>
                </StackPanel>
                
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search requests..."
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Margin="10,5,10,0"/>
            </StackPanel>

            <TreeView Grid.Row="1" 
                      ItemsSource="{Binding FilteredCollections}"
                      SelectedItemChanged="TreeView_SelectedItemChanged"
                      BorderThickness="0,1,0,0"
                      BorderBrush="#E0E0E0">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="Padding" Value="4,2"/>
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Requests}" DataType="{x:Type models:RequestCollection}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Folder" Foreground="Orange" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                        </StackPanel>
                        
                        <HierarchicalDataTemplate.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SavedRequest}">
                                <StackPanel Orientation="Horizontal" Background="Transparent"> <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Delete Request" 
                                                      Command="{Binding Data.DeleteRequestCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Delete" Foreground="Red" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>

                                    <TextBlock Text="{Binding Method}" 
                                               FontSize="10" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center" 
                                               Margin="0,0,8,0"
                                               Foreground="{Binding Method, Converter={StaticResource MethodToColorConverter}}"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
        
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent"/>
        
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Строка 0: URL + метод + кнопка Send -->
            <DockPanel Grid.Row="0" Margin="10" LastChildFill="True">
                <ComboBox ItemsSource="{Binding Methods }"
                          SelectedItem="{Binding SelectedMethod}"
                          Width="100" 
                          DockPanel.Dock="Left"/>
                
                <Button Content="Send" 
                        Command="{Binding SendCommand}"
                        Width="80" Margin="5,0,0,0" 
                        DockPanel.Dock="Right" />
                
                <ComboBox ItemsSource="{Binding Environments}"
                          SelectedItem="{Binding SelectedEnvironment}"
                          DisplayMemberPath="Name"
                          Width="150"
                          DockPanel.Dock="Right"
                          Margin="5,0"
                          materialDesign:HintAssist.Hint="No Environment"
                          materialDesign:TextFieldAssist.HasClearButton="True"/>
                
                <Button DockPanel.Dock="Right"
                        Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Toggle theme"
                        Margin="5,0">
                    <materialDesign:PackIcon Kind="ThemeLightDark"/>
                </Button>
                
                <!-- Auth-блок -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            Margin="5,0,0,0">

                    <!-- Залогинен: имя + Logout -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <materialDesign:PackIcon Kind="Account" 
                                                 VerticalAlignment="Center" 
                                                 Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding CurrentUsername}"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                        <Button Content="Logout"
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="8,4"/>
                    </StackPanel>

                    <!-- НЕ залогинен: поля + Login/Register + ошибка -->
                    <StackPanel Orientation="Vertical"
                                Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="120"
                                     Text="{Binding LoginUserName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Username"
                                     Margin="0,0,5,0"
                                     VerticalAlignment="Center"/>
                            <TextBox Width="120"
                                     Text="{Binding LoginPassword, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Password"
                                     Margin="0,0,5,0"
                                     VerticalAlignment="Center"/>
                            <Button Content="Login"
                                    Command="{Binding LoginCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Margin="0,0,3,0"
                                    Padding="8,4"/>
                            <Button Content="Register"
                                    Command="{Binding RegisterCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Padding="8,4"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AuthErrorMessage}"
                                   Foreground="Red"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

    <!-- Уже существующий TextBox с URL -->
    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
             Margin="5,0"
             VerticalAlignment="Center"
             materialDesign:HintAssist.Hint="Enter request URL (e.g. https://api.example.com)" 
             materialDesign:TextFieldAssist.HasClearButton="True"/>
            </DockPanel>
            
            <!-- Строка 1: ProgressBar -->
            
            <ProgressBar Grid.Row="1"
                         IsIndeterminate="True"
                         Height="4"
                         Visibility="{Binding IsLoading, 
                              Converter={StaticResource BooleanToVisibilityConverter}}"/>
            
            <!-- Строка 2: Вкладки Headers и Body -->
            <TabControl Grid.Row="2" Margin="10,0,10,5" MinHeight="150" MaxHeight="250">
                <TabItem Header="Headers">
                    <DockPanel>
                        <Button Content="+ Add Header"
                                Command="{Binding AddHeaderCommand}"
                                DockPanel.Dock="Bottom"
                                HorizontalAlignment="Left"
                                Margin="0,5,0,0"/>
                        
                        <DataGrid ItemsSource="{Binding Headers}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Key"
                                                    Binding="{Binding Key}"
                                                    Width="*"/>
                                
                                <DataGridTextColumn Header="Value"
                                                    Binding="{Binding Value}"
                                                    Width="2*"/>
                                
                                <DataGridTemplateColumn Header="" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕"
                                                    Command="{Binding DataContext.RemoveHeaderCommand, 
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="4,2"
                                                    MinWidth="0" MinHeight="0"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Foreground="Gray"
                                                    FontSize="12"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                
                <!-- Вкладка Body -->
                <TabItem Header="Body">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ComboBox Grid.Row="0"
                                  ItemsSource="{Binding BodyTypes}"
                                  SelectedItem="{Binding SelectedBodyType}"
                                  Width="160"
                                  HorizontalAlignment="Left"
                                  Margin="0,5,0,5"/>

                        <!-- JSON / Raw: текстовое поле -->
                        <TextBox Grid.Row="1"
                                 Text="{Binding RequestBody, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 Padding="5"
                                 Visibility="{Binding SelectedBodyType, Converter={StaticResource StringMatchToVisibilityConverter}, ConverterParameter=json|raw}"/>

                        <!-- Form-data: таблица Key/Value -->
                        <DockPanel Grid.Row="1"
                                   Visibility="{Binding SelectedBodyType, Converter={StaticResource StringMatchToVisibilityConverter}, ConverterParameter=form-data}">
                            <Button Content="+ Add Field"
                                    Command="{Binding AddFormDataItemCommand}"
                                    DockPanel.Dock="Bottom"
                                    HorizontalAlignment="Left"
                                    Margin="0,5,0,0"/>
                            <DataGrid ItemsSource="{Binding FormDataItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*"/>
                                    <DataGridTemplateColumn Header="" Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕"
                                                        Command="{Binding DataContext.RemoveFormDataItemCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="4,2"
                                                        MinWidth="0" MinHeight="0"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Foreground="Gray"
                                                        FontSize="12"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <!-- None: подсказка -->
                        <TextBlock Grid.Row="1"
                                   Text="No body for this request"
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding SelectedBodyType, Converter={StaticResource StringMatchToVisibilityConverter}, ConverterParameter=none}"/>
                    </Grid>
                </TabItem>
                
                <TabItem Header="Params">
                    <DockPanel>
                        <Button Content="+ Add Param"
                                Command="{Binding AddQueryParamCommand}"
                                DockPanel.Dock="Bottom"
                                HorizontalAlignment="Left"
                                Margin="0,5,0,0"/>

                        <DataGrid ItemsSource="{Binding QueryParams}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Key"
                                                    Binding="{Binding Key}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Value"
                                                    Binding="{Binding Value}"
                                                    Width="2*"/>
                                <DataGridTemplateColumn Header="" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕"
                                                    Command="{Binding DataContext.RemoveQueryParamCommand,
                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="4,2"
                                                    MinWidth="0" MinHeight="0"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Foreground="Gray"
                                                    FontSize="12"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                
                <TabItem Header="Environments">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Button Content="New Environment" 
                                    Command="{Binding CreateEnvironmentCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    FontSize="12"/>
                            <Button Content="Delete Current Env" 
                                    Command="{Binding DeleteEnvironmentCommand}"
                                    CommandParameter="{Binding SelectedEnvironment}"
                                    Foreground="Red"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    FontSize="12"
                                    Margin="10,0,0,0"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" 
                                  ItemsSource="{Binding SelectedEnvironment.Variables}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  Margin="0,5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Variable (Key)" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*"/>
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕"
                                                    Command="{Binding DataContext.RemoveVariableCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Foreground="Gray" FontSize="12"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="2" 
                                Content="+ Add Variable"
                                Command="{Binding AddVariableCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,5,0,0"
                                IsEnabled="{Binding SelectedEnvironment, Converter={StaticResource SelectedToEnabledConverter}}"/> 
                                </Grid>
                </TabItem>
                
                <TabItem Header="Auth">
    <StackPanel Margin="8">
        <ComboBox ItemsSource="{Binding AuthTypes}"
                  SelectedItem="{Binding SelectedAuthType}"
                  Width="200"
                  HorizontalAlignment="Left"
                  Margin="0,5,0,10"
                  materialDesign:HintAssist.Hint="Auth Type"/>

        <!-- Bearer Token -->
        <StackPanel Visibility="{Binding SelectedAuthType,
                    Converter={StaticResource StringMatchToVisibilityConverter},
                    ConverterParameter=Bearer Token}">
            <TextBlock Text="Token" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding BearerToken, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Enter bearer token"
                     Margin="0,0,0,8"/>
        </StackPanel>

        <!-- Basic Auth -->
        <StackPanel Visibility="{Binding SelectedAuthType,
                    Converter={StaticResource StringMatchToVisibilityConverter},
                    ConverterParameter=Basic Auth}">
            <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding BasicAuthUsername, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Username"
                     Margin="0,0,0,8"/>
            <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding BasicAuthPassword, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Password"
                     Margin="0,0,0,8"/>
        </StackPanel>

        <!-- API Key -->
        <StackPanel Visibility="{Binding SelectedAuthType,
                    Converter={StaticResource StringMatchToVisibilityConverter},
                    ConverterParameter=API Key}">
            <TextBlock Text="Key Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ApiKeyName, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Header name (e.g. X-API-Key)"
                     Margin="0,0,0,8"/>
            <TextBlock Text="Key Value" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ApiKeyValue, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="API key value"
                     Margin="0,0,0,8"/>
        </StackPanel>

        <!-- None -->
        <TextBlock Text="No authorization"
                   Foreground="Gray"
                   Margin="0,10,0,0"
                   Visibility="{Binding SelectedAuthType,
                   Converter={StaticResource StringMatchToVisibilityConverter},
                   ConverterParameter=None}"/>
    </StackPanel>
</TabItem>
                
                <TabItem Header="Tests">
    <DockPanel>
        <Button Content="+ Add Test"
                Command="{Binding AddTestCommand}"
                DockPanel.Dock="Bottom"
                HorizontalAlignment="Left"
                Margin="0,5,0,0"/>
        <DataGrid ItemsSource="{Binding Tests}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Type"
                                        SelectedItemBinding="{Binding TestType}"
                                        Width="*">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.TestTypes, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding DataContext.TestTypes, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>
                <DataGridTextColumn Header="Expected Value"
                                    Binding="{Binding ExpectedValue}"
                                    Width="*"/>
                <DataGridTemplateColumn Header="" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕"
                                    Command="{Binding DataContext.RemoveTestCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Padding="4,2"
                                    MinWidth="0" MinHeight="0"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="Gray"
                                    FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</TabItem>
                
                <TabItem Header="WebSocket">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- URL + Connect/Disconnect -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Content="Disconnect"
                    Command="{Binding WsDisconnectCommand}"
                    DockPanel.Dock="Right"
                    Margin="5,0,0,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Padding="12,4"/>
            <Button Content="Connect"
                    Command="{Binding WsConnectCommand}"
                    DockPanel.Dock="Right"
                    Margin="5,0,0,0"
                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                    Padding="12,4"/>
            <TextBox Text="{Binding WsUrl, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="ws://echo.websocket.org"
                     VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Status -->
        <TextBlock Grid.Row="1" Margin="0,0,0,6">
            <Run Text="Status: " FontWeight="SemiBold"/>
            <Run Text="{Binding WsStatus}"/>
        </TextBlock>

        <!-- Messages -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding WsMessages}"
                 FontFamily="Consolas"
                 FontSize="12"
                 BorderThickness="1"
                 BorderBrush="Gray"/>

        <!-- Send -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <Button Content="Clear"
                    Command="{Binding WsClearMessagesCommand}"
                    DockPanel.Dock="Right"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Padding="8,4"
                    Margin="5,0,0,0"/>
            <Button Content="Send"
                    Command="{Binding WsSendCommand}"
                    DockPanel.Dock="Right"
                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                    Padding="12,4"
                    Margin="5,0,0,0"/>
            <TextBox Text="{Binding WsMessageToSend, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Message to send..."
                     VerticalAlignment="Center"/>
        </DockPanel>
    </Grid>
</TabItem>
                
                
                
            </TabControl>
            
            <!-- Строка 3: Статус ответа-->
            <Border Grid.Row="3" 
                    Background="{Binding StatusInfo, Converter={StaticResource StatusCodeToBrushConverter}}" 
                    Margin="10,8,10,4" 
                    CornerRadius="4">
                <TextBlock Text="{Binding StatusInfo}"
                           FontWeight="Bold"
                           Padding="12,6"
                           Foreground="White"/>
            </Border>
            
            <!-- Строка 4: Вкладки ответа -->
            <TabControl Grid.Row="4" 
                        Margin="10,0,10,10"
                        SelectedIndex="0">
                <TabItem Header="Body">
                    <DockPanel>
                        <Button Content="Copy"
                                Command="{Binding CopyResponseCommand}"
                                DockPanel.Dock="Top"
                                HorizontalAlignment="Right"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="8,4"
                                Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ResponseBody, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </DockPanel>
                </TabItem>
                
                <TabItem Header="Headers">
                    <TextBox Text="{Binding ResponseHeadersText, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             BorderThickness="0"
                             Padding="8"/>
                </TabItem>
                
                <TabItem Header="History">
                    <DataGrid ItemsSource="{Binding RequestHistory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="60"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="3*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusCode}" Width="60"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding ElapsedTime}" Width="80"/>
                            <DataGridTextColumn Header="Sent at" Binding="{Binding SentAt, StringFormat=HH:mm:ss}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                
                <TabItem Header="Code">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,4,0,4">
                            <ComboBox ItemsSource="{Binding CodeFormats}"
                                      SelectedItem="{Binding SelectedCodeFormat}"
                                      Width="150"
                                      Margin="0,0,8,0"/>
                            <Button Content="Generate"
                                    Command="{Binding GenerateCodeCommand}"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                    Padding="12,4"
                                    Margin="0,0,8,0"/>
                            <Button Content="Copy"
                                    Command="{Binding CopyGeneratedCodeCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Padding="8,4"/>
                        </StackPanel>
                        <TextBox Text="{Binding GeneratedCode, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 BorderThickness="0"
                                 Padding="8"/>
                    </DockPanel>
                </TabItem>
                
                <TabItem Header="Test Results">
                    <ListView ItemsSource="{Binding TestResults}" Padding="8">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Ellipse Width="12" Height="12"
                                             Fill="{Binding Passed, Converter={StaticResource BoolToTestResultBrushConverter}}"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Description}"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabItem>
                
            </TabControl>
        </Grid>
    </Grid>
</Window>
